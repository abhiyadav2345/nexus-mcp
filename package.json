{
  "name": "@nexus-mcp/cli",
  "version": "0.1.0",
  "description": "Production-grade MCP server linter, contract tester, and quality intelligence CLI",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "linter",
    "testing",
    "cli"
  ],
  "homepage": "https://github.com/nexus-mcp/cli",
  "license": "MIT",
  "author": "Abhishek Yadav",
  "type": "module",
  "bin": {
    "nexus": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "yaml": "^2.4.5",
    "zod": "^3.23.8",
    "boxen": "^8.0.1",
    "table": "^6.8.2",
    "fast-check": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.12.0",
    "npm": ">=9.0.0"
  }
}
